# MULTI STAGE DOCKER FILE

FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json .

RUN npm install 

COPY . .

RUN npm run build

FROM nginx:alpine

WORKDIR /app

COPY --from=builder /app/build /usr/share/nginx/html

EXPOSE 80

CMD ["nginx","-g","daemon off ;"]

#----------------------------------------------------------------------------------------------------------------------